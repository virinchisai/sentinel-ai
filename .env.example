# LLM provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model names per provider
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# GitHub connector
GITHUB_TOKEN=
GITHUB_DEFAULT_REPO=octocat/Hello-World

# MCP server auth (bearer token clients must send)
MCP_AUTH_TOKEN=dev-secret-change-me

# RAG
CHROMA_PERSIST_DIR=.chroma

# API server
API_HOST=0.0.0.0
API_PORT=8000
