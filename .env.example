# ─── LLM provider ─────────────────────────────────────────────
# Pick one: "anthropic" or "openai"
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# ─── MCP enterprise connectors ────────────────────────────────
# Leave blank to run in mock mode (returns realistic sample data).
GITHUB_TOKEN=
GITHUB_DEFAULT_REPO=octocat/Hello-World
GMAIL_CREDENTIALS_JSON=
GOOGLE_CALENDAR_CREDENTIALS_JSON=

# Sandboxed FS connector — agent can only read files under this dir.
WORKSPACE_DIR=./workspace

# ─── Auth & security ──────────────────────────────────────────
# IMPORTANT: rotate this for production. Used to sign JWTs.
JWT_SECRET_KEY=sentinel-ai-dev-secret-change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Bearer token gating the standalone MCP HTTP transport.
MCP_AUTH_TOKEN=dev-secret-change-me

# ─── Database ─────────────────────────────────────────────────
# SQLite for local dev; switch to postgresql://user:pass@host/db in prod.
DATABASE_URL=sqlite:///sentinel.db

# ─── RAG ──────────────────────────────────────────────────────
RAG_BACKEND=chroma          # or "pgvector"
CHROMA_PERSIST_DIR=.chroma

# ─── Observability ────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_METRICS=true

# ─── API server ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
